{
  "name": "adb-tool",
  "version": "1.0.0",
  "description": "ADB 指令图形化工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.adb.tool",
    "productName": "ADB Tool",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "extraResources": [
      {
        "from": "default-commands.json",
        "to": "default-commands.json"
      }
    ]
  }
}
